generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  ADMIN
  RECRUITER
  CANDIDATE
}

model User {
  id String @id @default(cuid())

  firstName String

  lastName String

  email String @unique

  password String?

  photo String?

  role Role @default(CANDIDATE)

  provider String?

  isVerified Boolean @default(false)

  verificationToken String?

  resetPasswordToken String?

  isBlocked Boolean @default(false)

  createdAt DateTime @default(now())

  updatedAt DateTime @updatedAt
  version   Int      @default(1) // For optimistic locking

  //relation
  profile        Profile?
  projects       Project[]
  cvs            CV[]
  userAttributes UserAttribute[]
  discussions    Discussion[]
  comments       Comment[]
  commentLikes   CommentLike[]
  likes          Like[]
}

model Profile {
  id        String    @id @default(uuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  firstName String
  lastName  String
  location  String?
  photoUrl  String?
  version   Int       @default(1) // Optimistic locking
  updatedAt DateTime? @updatedAt
}

model AttributeLibrary {
  id             String          @id @default(uuid())
  label          String          @unique
  type           String // e.g., "TEXT", "NUMBER", "BOOLEAN"
  isBuiltIn      Boolean         @default(false) // 'Me' section templates fields
  userAttributes UserAttribute[]
  templateFields TemplateField[]
}

model UserAttribute {
  id          String           @id @default(uuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   AttributeLibrary @relation(fields: [attributeId], references: [id], onDelete: Cascade)
  value       String // Dynamic values stringified or plain text
  version     Int              @default(1)

  @@unique([userId, attributeId])
}

model Project {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  name        String
  startDate   DateTime
  endDate     DateTime?
  description String // Markdown supported text
  tags        String[] // Technology tags
  version     Int       @default(1)
}

model Position {
  id          String          @id @default(uuid())
  title       String
  description String
  isActive    Boolean         @default(true)
  version     Int             @default(1)
  templates   TemplateField[]
  cvs         CV[]
  discussions Discussion[]
}

model TemplateField {
  id          String           @id @default(uuid())
  positionId  String
  position    Position         @relation(fields: [positionId], references: [id], onDelete: Cascade)
  attributeId String
  attribute   AttributeLibrary @relation(fields: [attributeId], references: [id], onDelete: Cascade)

  @@unique([positionId, attributeId])
}

model CV {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  positionId String
  position   Position @relation(fields: [positionId], references: [id], onDelete: Cascade)
  content    Json // Automatically compiled standard & custom attribute snapshot
  version    Int      @default(1)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, positionId]) // Max 1 CV per position per candidate
}

model Discussion {
  id         String    @id @default(uuid())
  positionId String
  position   Position  @relation(fields: [positionId], references: [id], onDelete: Cascade)
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  title      String
  content    String
  createdAt  DateTime  @default(now())
  comments   Comment[]
}

model Comment {
  id           String     @id @default(uuid())
  discussionId String
  discussion   Discussion @relation(fields: [discussionId], references: [id], onDelete: Cascade)
  userId       String
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  text         String
  createdAt    DateTime   @default(now())

  // Self-relation (Reply Functionality) এর জন্য নতুন ফিল্ডস
  parentId String? // যদি কোনো কমেন্টের আন্ডারে রিপ্লাই হয়, তবে মেইন কমেন্টের ID
  parent   Comment?  @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Comment[] @relation("CommentReplies")

  // Likes Functionality এর জন্য নতুন ফিল্ড
  likes CommentLike[]
}

model CommentLike {
  id        String   @id @default(uuid())
  commentId String
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, commentId])
}

model Like {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cvId      String
  createdAt DateTime @default(now())

  @@unique([userId, cvId])
}
